<!DOCTYPE html>
<html>
<head>
<style>
body {
  margin: 0;
  font-family: Arial;
}

/* Footer */
.footer {
  background: #111;
  color: white;
  padding: 40px 20px;
}

.footer-container {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
}

/* Columns */
.footer-col {
  width: 30%;
}

.footer-col h3 {
  margin-bottom: 15px;
}

.footer-col ul {
  list-style: none;
  padding: 0;
}

.footer-col ul li {
  margin: 8px 0;
}

.footer-col ul li a {
  color: white;
  text-decoration: none;
}

.footer-col ul li a:hover {
  color: yellow;
}

/* Social icons */
.social span {
  margin-right: 10px;
  font-size: 20px;
  cursor: pointer;
}

.social span:hover {
  color: yellow;
}

/* Bottom */
.footer-bottom {
  text-align: center;
  margin-top: 20px;
  border-top: 1px solid gray;
  padding-top: 10px;
}

/* Responsive */
@media(max-width:600px) {
  .footer-col {
    width: 100%;
    margin-bottom: 20px;
  }
}
</style>
</head>
<body>

<footer class="footer">
  <div class="footer-container">

    <!-- About -->
    <div class="footer-col">
      <h3>About</h3>
      <p>This is a simple website footer design for assignment.</p>
    </div>

    <!-- Quick Links -->
    <div class="footer-col">
      <h3>Quick Links</h3>
      <ul>
        <li><a href="#">Home</a></li>
        <li><a href="#">About</a></li>
        <li><a href="#">Contact</a></li>
      </ul>
    </div>

    <!-- Social -->
    <div class="footer-col">
      <h3>Follow Us</h3>
      <div class="social">
        <span>🌐</span>
        <span>📘</span>
        <span>🐦</span>
      </div>
    </div>

  </div>

  <div class="footer-bottom">
    <p>© 2026 All Rights Reserved</p>
  </div>
</footer>

</body>
</html>
